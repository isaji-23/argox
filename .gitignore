# =============================================================================
# Argox — .gitignore
# Monorepo Python: argox-core + argox-plugin-*
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Distribución / empaquetado
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# Entornos virtuales
.venv/
venv/
env/
.env/

# -----------------------------------------------------------------------------
# Variables de entorno y secretos
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Testing y cobertura
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# Herramientas de desarrollo
# -----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pytype/

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
# Sistema operativo
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Argox — ficheros generados en runtime
# -----------------------------------------------------------------------------
# Logs de ejecuciones de agentes (JsonlExporter)
agent_runs.jsonl
*.jsonl

# Registry local de agentes (AgentRegistry)
agent_registry.jsonl

# SQLite (índice local MVP)
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Claude Code — per-session doc-nudge markers (see .claude/hooks)
# -----------------------------------------------------------------------------
.argox/

.untracked/